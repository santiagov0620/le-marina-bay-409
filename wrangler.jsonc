{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "le-marina-bay-409",
  "compatibility_date": "2026-06-02",
  "workers_dev": false,
  "routes": [
    { "pattern": "lemarinabay409.com", "custom_domain": true },
    { "pattern": "www.lemarinabay409.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
